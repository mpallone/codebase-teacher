# LLM Provider Backend
# Default is claude-code (uses the `claude` CLI, no API key required)
# CODEBASE_TEACHER_PROVIDER=claude-code

# To use litellm (API key mode) instead:
# CODEBASE_TEACHER_PROVIDER=litellm

# API Keys (only needed with litellm provider)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# Model selection (only used with litellm provider)
# CODEBASE_TEACHER_MODEL=anthropic/claude-sonnet-4-20250514
