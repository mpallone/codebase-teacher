# LLM Provider API Keys
# Uncomment and set the key for your chosen provider

# Anthropic (Claude)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GEMINI_API_KEY=...

# Default model to use (provider/model format for litellm)
# CODEBASE_TEACHER_MODEL=anthropic/claude-sonnet-4-20250514
