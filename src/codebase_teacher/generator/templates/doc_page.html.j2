<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ project_name }} &mdash; codebase-teacher</title>
  <style>
    /* --- CSS Custom Properties (Light / Dark) --- */
    :root,
    [data-theme="light"] {
      --bg: #ffffff;
      --bg-sidebar: #f7f8fa;
      --bg-code: #f4f4f5;
      --bg-details: #fafafa;
      --text: #1a1a1a;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --link: #2563eb;
      --link-hover: #1d4ed8;
      --accent: #3b82f6;
      --sidebar-active: #eff6ff;
    }
    [data-theme="dark"] {
      --bg: #111827;
      --bg-sidebar: #1f2937;
      --bg-code: #1e293b;
      --bg-details: #1a2332;
      --text: #e5e7eb;
      --text-muted: #9ca3af;
      --border: #374151;
      --link: #60a5fa;
      --link-hover: #93bbfd;
      --accent: #3b82f6;
      --sidebar-active: #1e3a5f;
    }

    /* --- Reset & Base --- */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      font-size: 16px;
      line-height: 1.7;
      color: var(--text);
      background: var(--bg);
    }

    /* --- Sidebar --- */
    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      width: 260px;
      height: 100vh;
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 1.5rem 0;
      z-index: 100;
      transition: transform 0.3s ease;
    }
    .sidebar-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1.25rem 1rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 0.75rem;
    }
    .sidebar-header h2 {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .sidebar ul { list-style: none; }
    .sidebar li a {
      display: block;
      padding: 0.5rem 1.25rem;
      color: var(--text-muted);
      text-decoration: none;
      font-size: 0.9rem;
      border-left: 3px solid transparent;
      transition: all 0.15s ease;
    }
    .sidebar li a:hover,
    .sidebar li a.active {
      color: var(--link);
      background: var(--sidebar-active);
      border-left-color: var(--accent);
    }

    /* --- Theme Toggle --- */
    .theme-toggle {
      background: none;
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.3rem 0.5rem;
      cursor: pointer;
      color: var(--text);
      font-size: 1rem;
      flex-shrink: 0;
    }
    .theme-toggle:hover { background: var(--border); }

    /* --- Hamburger --- */
    .hamburger {
      display: none;
      position: fixed;
      top: 0.75rem;
      left: 0.75rem;
      z-index: 200;
      background: var(--bg-sidebar);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 0.4rem 0.65rem;
      font-size: 1.3rem;
      cursor: pointer;
      color: var(--text);
    }

    /* --- Sidebar Overlay (mobile) --- */
    .sidebar-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.4);
      z-index: 90;
    }

    /* --- Main Content --- */
    .content {
      margin-left: 260px;
      max-width: 52rem;
      padding: 2rem 2.5rem 4rem;
    }

    /* --- Sections --- */
    .content section {
      margin-bottom: 3rem;
      padding-top: 1rem;
    }
    .content section > h1 {
      font-size: 1.65rem;
      font-weight: 700;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid var(--border);
    }

    /* --- Details / Collapsible --- */
    details {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      margin: 1rem 0;
      background: var(--bg-details);
    }
    details summary {
      cursor: pointer;
      font-weight: 600;
      font-size: 1.05rem;
      color: var(--text);
      padding: 0.25rem 0;
      list-style-type: none;
    }
    details summary::-webkit-details-marker { display: none; }
    details summary::before {
      content: "\25B6\FE0E";
      display: inline-block;
      margin-right: 0.5rem;
      transition: transform 0.2s ease;
      font-size: 0.75rem;
    }
    details[open] summary::before { transform: rotate(90deg); }
    details > *:not(summary) { margin-top: 0.75rem; }

    /* --- Typography inside sections --- */
    .section-body h1 { font-size: 1.5rem; margin: 1.5rem 0 0.75rem; }
    .section-body h2 { font-size: 1.3rem; margin: 1.25rem 0 0.6rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
    .section-body h3 { font-size: 1.1rem; margin: 1rem 0 0.5rem; }
    .section-body p { margin: 0.6rem 0; }
    .section-body ul, .section-body ol { margin: 0.5rem 0 0.5rem 1.5rem; }
    .section-body li { margin: 0.25rem 0; }
    .section-body a { color: var(--link); text-decoration: none; }
    .section-body a:hover { color: var(--link-hover); text-decoration: underline; }
    .section-body strong { font-weight: 600; }
    .section-body blockquote {
      border-left: 4px solid var(--accent);
      padding: 0.5rem 1rem;
      margin: 0.75rem 0;
      color: var(--text-muted);
      background: var(--bg-code);
      border-radius: 0 6px 6px 0;
    }
    .section-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 0.75rem 0;
      font-size: 0.9rem;
    }
    .section-body th, .section-body td {
      padding: 0.5rem 0.75rem;
      border: 1px solid var(--border);
      text-align: left;
    }
    .section-body th { background: var(--bg-code); font-weight: 600; }

    /* --- Code --- */
    .section-body code {
      font-family: "SF Mono", "Fira Code", "Fira Mono", Menlo, Consolas, monospace;
      font-size: 0.875em;
      background: var(--bg-code);
      padding: 0.15em 0.35em;
      border-radius: 4px;
    }
    .section-body pre {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      overflow-x: auto;
      margin: 0.75rem 0;
      font-size: 0.875rem;
      line-height: 1.5;
    }
    .section-body pre code {
      background: none;
      padding: 0;
      border-radius: 0;
    }

    /* --- Mermaid Diagrams --- */
    pre.mermaid {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.5rem;
      text-align: center;
      overflow-x: auto;
    }
    /* Fallback styling when a diagram fails to render */
    pre.mermaid-error {
      background: var(--bg-code);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      text-align: left;
      font-family: "SF Mono", "Fira Code", Menlo, Consolas, monospace;
      font-size: 0.8rem;
      white-space: pre-wrap;
      color: var(--text-muted);
      overflow-x: auto;
    }
    pre.mermaid-error::before {
      content: "Diagram source (failed to render):";
      display: block;
      font-weight: 600;
      margin-bottom: 0.5rem;
      color: var(--text);
    }

    /* --- JS error panel (hidden unless errors occur) --- */
    #js-error-panel {
      margin-top: 2rem;
      padding: 1rem 1.25rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg-code);
    }
    .js-error-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
      margin-bottom: 0.75rem;
    }
    .js-error-header h2 { margin: 0; font-size: 1rem; }
    #js-error-copy {
      cursor: pointer;
      padding: 0.4rem 0.8rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg);
      color: var(--text);
      font: inherit;
    }
    #js-error-copy:hover { border-color: var(--text-muted); }
    #js-error-log {
      max-height: 320px;
      overflow: auto;
      white-space: pre-wrap;
      font-family: "SF Mono", "Fira Code", Menlo, Consolas, monospace;
      font-size: 0.8rem;
      margin: 0;
      color: var(--text);
    }

    /* --- Footer --- */
    footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.85rem;
    }

    /* --- Responsive (mobile) --- */
    @media (max-width: 768px) {
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); }
      .sidebar-overlay.open { display: block; }
      .hamburger { display: block; }
      .content {
        margin-left: 0;
        padding: 3.5rem 1.25rem 3rem;
      }
    }
  </style>
</head>
<body>
  <nav class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <h2>{{ project_name }}</h2>
      <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme">
        <span id="theme-icon">&#9789;</span>
      </button>
    </div>
    <ul>
      {% for section in sections %}
      <li><a href="#{{ section.slug }}">{{ section.title }}</a></li>
      {% endfor %}
    </ul>
  </nav>

  <div class="sidebar-overlay" id="sidebar-overlay" onclick="closeSidebar()"></div>

  <button class="hamburger" id="hamburger" onclick="toggleSidebar()" aria-label="Toggle navigation">&#9776;</button>

  <main class="content">
    {% for section in sections %}
    <section id="{{ section.slug }}">
      <h1>{{ section.title }}</h1>
      <details open>
        <summary>{{ section.title }}</summary>
        <div class="section-body">
          {{ section.html_content }}
        </div>
      </details>
    </section>
    {% endfor %}
    <footer><em>Generated by codebase-teacher</em></footer>
    <section id="js-error-panel" hidden aria-live="polite">
      <div class="js-error-header">
        <h2>JavaScript errors (<span id="js-error-count">0</span>)</h2>
        <button type="button" id="js-error-copy" onclick="copyJsErrors()">Copy to clipboard</button>
      </div>
      <pre id="js-error-log"></pre>
    </section>
  </main>

  <script>
    /* --- JS error collector (installed before mermaid loads) --- */
    var jsErrors = [];
    function formatJsError(entry) {
      var lines = [
        '[' + entry.time + '] ' + entry.source + ': ' + entry.message,
      ];
      if (entry.location) lines.push('  at ' + entry.location);
      if (entry.stack) lines.push(entry.stack);
      return lines.join('\n');
    }
    function renderErrorPanel() {
      var panel = document.getElementById('js-error-panel');
      var log = document.getElementById('js-error-log');
      var count = document.getElementById('js-error-count');
      if (!panel || !log || !count) return;
      panel.hidden = jsErrors.length === 0;
      count.textContent = String(jsErrors.length);
      log.textContent = jsErrors.map(formatJsError).join('\n\n');
    }
    function recordJsError(source, message, detail) {
      var entry = {
        time: new Date().toISOString(),
        source: source || 'window',
        message: String(message || ''),
        location: '',
        stack: '',
      };
      if (detail && typeof detail === 'object') {
        if (detail.stack) entry.stack = String(detail.stack);
        else if (detail.message && !entry.message) entry.message = String(detail.message);
        if (detail.filename) {
          entry.location = detail.filename +
            (detail.lineno ? ':' + detail.lineno : '') +
            (detail.colno ? ':' + detail.colno : '');
        }
      } else if (detail) {
        entry.stack = String(detail);
      }
      jsErrors.push(entry);
      /* Panel may not exist yet if an error fires before DOMContentLoaded; retry. */
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', renderErrorPanel, { once: true });
      } else {
        renderErrorPanel();
      }
    }
    window.addEventListener('error', function(event) {
      var msg = (event && event.message) || 'Uncaught error';
      recordJsError('window.onerror', msg, {
        stack: event && event.error && event.error.stack,
        filename: event && event.filename,
        lineno: event && event.lineno,
        colno: event && event.colno,
      });
    }, true);
    window.addEventListener('unhandledrejection', function(event) {
      var reason = event && event.reason;
      var msg = (reason && reason.message) || String(reason);
      recordJsError('unhandledrejection', msg, reason);
    });
    function copyJsErrors() {
      var log = document.getElementById('js-error-log');
      var btn = document.getElementById('js-error-copy');
      if (!log || !btn) return;
      var text = log.textContent || '';
      var done = function() {
        var original = 'Copy to clipboard';
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = original; }, 1500);
      };
      var fallback = function() {
        try {
          var ta = document.createElement('textarea');
          ta.value = text;
          ta.setAttribute('readonly', '');
          ta.style.position = 'absolute';
          ta.style.left = '-9999px';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          done();
        } catch (e) {
          btn.textContent = 'Copy failed — select text manually';
        }
      };
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(done, fallback);
      } else {
        fallback();
      }
    }
  </script>

  <script src="https://cdn.jsdelivr.net/npm/mermaid@11.4.1/dist/mermaid.min.js"></script>
  <script>
    /* --- Mermaid with error recovery --- */
    /* Store original source so we can re-render on theme toggle */
    var mermaidSources = {};
    (function() {
      document.querySelectorAll('pre.mermaid').forEach(function(el, i) {
        mermaidSources[i] = el.textContent;
        el.setAttribute('data-mermaid-id', i);
      });
    })();

    function getMermaidTheme() {
      return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default';
    }

    try {
      mermaid.initialize({
        startOnLoad: false,
        theme: getMermaidTheme(),
        securityLevel: 'loose',
        flowchart: { useMaxWidth: true, htmlLabels: true },
        sequence: { useMaxWidth: true },
      });
    } catch (e) {
      recordJsError('mermaid-init', 'mermaid.initialize failed', e);
    }

    /* Render each diagram individually so one failure doesn't block the rest */
    async function renderAllMermaid() {
      /* Drop stale mermaid errors from a previous render pass (e.g. after theme toggle) */
      jsErrors = jsErrors.filter(function(e) { return e.source !== 'mermaid'; });
      renderErrorPanel();
      var diagrams = document.querySelectorAll('pre.mermaid');
      for (var i = 0; i < diagrams.length; i++) {
        var el = diagrams[i];
        var id = el.getAttribute('data-mermaid-id');
        var source = mermaidSources[id] || el.textContent;
        try {
          var valid = await mermaid.parse(source);
          if (valid) {
            var result = await mermaid.render('mermaid-svg-' + id + '-' + Date.now(), source);
            el.innerHTML = result.svg;
            el.classList.remove('mermaid-error');
          }
        } catch (e) {
          /* Show source code as fallback instead of a broken diagram */
          el.textContent = source;
          el.classList.remove('mermaid');
          el.classList.add('mermaid-error');
          recordJsError('mermaid', 'Failed to render diagram #' + id, e);
        }
      }
    }
    renderAllMermaid();

    /* --- Theme Toggle --- */
    function toggleTheme() {
      var html = document.documentElement;
      var current = html.getAttribute('data-theme');
      var next = current === 'dark' ? 'light' : 'dark';
      html.setAttribute('data-theme', next);
      localStorage.setItem('codebase-teacher-theme', next);
      updateThemeIcon(next);
      /* Re-render mermaid diagrams with matching theme */
      mermaid.initialize({
        startOnLoad: false,
        theme: next === 'dark' ? 'dark' : 'default',
        securityLevel: 'loose',
        flowchart: { useMaxWidth: true, htmlLabels: true },
        sequence: { useMaxWidth: true },
      });
      /* Restore original source before re-rendering */
      document.querySelectorAll('[data-mermaid-id]').forEach(function(el) {
        var id = el.getAttribute('data-mermaid-id');
        if (mermaidSources[id]) {
          el.innerHTML = mermaidSources[id];
          el.classList.remove('mermaid-error');
          el.classList.add('mermaid');
        }
      });
      renderAllMermaid();
    }
    function updateThemeIcon(theme) {
      document.getElementById('theme-icon').innerHTML = theme === 'dark' ? '&#9788;' : '&#9789;';
    }
    /* Restore saved preference */
    (function() {
      var saved = localStorage.getItem('codebase-teacher-theme');
      if (saved) {
        document.documentElement.setAttribute('data-theme', saved);
        updateThemeIcon(saved);
      }
    })();

    /* --- Sidebar Toggle (mobile) --- */
    function toggleSidebar() {
      document.getElementById('sidebar').classList.toggle('open');
      document.getElementById('sidebar-overlay').classList.toggle('open');
    }
    function closeSidebar() {
      document.getElementById('sidebar').classList.remove('open');
      document.getElementById('sidebar-overlay').classList.remove('open');
    }
    /* Close sidebar on nav link click (mobile) */
    document.querySelectorAll('.sidebar a').forEach(function(link) {
      link.addEventListener('click', closeSidebar);
    });

    /* --- Active nav highlight on scroll --- */
    (function() {
      var sections = document.querySelectorAll('.content section[id]');
      var navLinks = document.querySelectorAll('.sidebar a');
      window.addEventListener('scroll', function() {
        var scrollPos = window.scrollY + 120;
        sections.forEach(function(section) {
          if (section.offsetTop <= scrollPos && section.offsetTop + section.offsetHeight > scrollPos) {
            navLinks.forEach(function(link) {
              link.classList.remove('active');
              if (link.getAttribute('href') === '#' + section.id) {
                link.classList.add('active');
              }
            });
          }
        });
      });
    })();
  </script>
</body>
</html>
